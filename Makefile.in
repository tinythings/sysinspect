ARC_VERSION := $(shell cat src/main.rs | grep 'static VERSION' | sed -e 's/.*=//g' -e 's/[" ;]//g')
ARC_NAME := sysinspect-${ARC_VERSION}
PACK_LAYOUT_DIRS := sys net fs runtime cfg
UNAME_S := $(shell uname -s)
UNAME_M := $(shell uname -m)
WASM_DEMO_COMPILER ?= $(shell if command -v go >/dev/null 2>&1; then printf go; elif command -v tinygo >/dev/null 2>&1; then printf tinygo; fi)
STATIC_LIBRARY_PAYLOAD_PATHS := modules/runtime/lua-runtime/examples/lib modules/runtime/py3-runtime/examples/lib
PKG_SPEC_FROM_TOML = $(shell awk 'BEGIN{name=""; version=""} /^name = / && name == "" { gsub(/"/, "", $$3); name = $$3 } /^version = / && version == "" { gsub(/"/, "", $$3); version = $$3 } END { if (name != "" && version != "") printf "%s@%s", name, version }' $(1))
ALL_MODULE_PACKAGE_SPECS := $(shell find modules -maxdepth 3 -name Cargo.toml -print | sort | while read f; do \
	awk 'BEGIN{name=""; version=""} \
		/^name = / && name == "" { gsub(/"/, "", $$3); name = $$3 } \
		/^version = / && version == "" { gsub(/"/, "", $$3); version = $$3 } \
		END { if (name != "" && version != "") printf "%s@%s ", name, version }' "$$f"; \
done)
PY3_RUNTIME_SPEC := $(call PKG_SPEC_FROM_TOML,modules/runtime/py3-runtime/Cargo.toml)
MUSL_UNSAFE_PACKAGE_SPECS := $(PY3_RUNTIME_SPEC)
ifeq ($(UNAME_S),NetBSD)
MODULE_PACKAGE_SPECS := $(filter-out $(PY3_RUNTIME_SPEC),$(ALL_MODULE_PACKAGE_SPECS))
PLATFORM_WORKSPACE_EXCLUDES := --exclude $(PY3_RUNTIME_SPEC)
else
MODULE_PACKAGE_SPECS := $(ALL_MODULE_PACKAGE_SPECS)
PLATFORM_WORKSPACE_EXCLUDES :=
endif
MUSL_MODULE_PACKAGE_SPECS := $(filter-out $(MUSL_UNSAFE_PACKAGE_SPECS),$(MODULE_PACKAGE_SPECS))
NATIVE_REFRESH_PACKAGE_SPECS := $(filter $(MUSL_UNSAFE_PACKAGE_SPECS),$(MODULE_PACKAGE_SPECS))
SENSOR_PACKAGE_SPECS := $(foreach f,libsensors/Cargo.toml libmenotify/Cargo.toml,$(call PKG_SPEC_FROM_TOML,$(f)))
CORE_PACKAGE_SPECS := $(strip \
	$(call PKG_SPEC_FROM_TOML,Cargo.toml) \
	$(call PKG_SPEC_FROM_TOML,libsysinspect/Cargo.toml) \
	$(call PKG_SPEC_FROM_TOML,libeventreg/Cargo.toml) \
	$(call PKG_SPEC_FROM_TOML,sysmaster/Cargo.toml) \
	$(call PKG_SPEC_FROM_TOML,sysminion/Cargo.toml) \
	$(call PKG_SPEC_FROM_TOML,libsetup/Cargo.toml) \
	$(call PKG_SPEC_FROM_TOML,libscheduler/Cargo.toml) \
	$(call PKG_SPEC_FROM_TOML,libmodpak/Cargo.toml) \
	$(call PKG_SPEC_FROM_TOML,libmodcore/Cargo.toml) \
	$(call PKG_SPEC_FROM_TOML,libtelemetry/Cargo.toml) \
	$(call PKG_SPEC_FROM_TOML,libwebapi/Cargo.toml) \
	$(call PKG_SPEC_FROM_TOML,sysclient/Cargo.toml) \
	$(call PKG_SPEC_FROM_TOML,libdpq/Cargo.toml) \
	$(call PKG_SPEC_FROM_TOML,libsysproto/Cargo.toml) \
	$(call PKG_SPEC_FROM_TOML,libcommon/Cargo.toml) \
	$(call PKG_SPEC_FROM_TOML,libdatastore/Cargo.toml))
INTEGRATION_TEST_TARGETS := $(shell find . -path '*/tests/*.rs' | sort | while read f; do \
	dir=$$(dirname "$$f"); \
	base=$$(basename "$$f" .rs); \
	crate_dir=$$(dirname "$$dir"); \
	if [ -f "$$crate_dir/Cargo.toml" ]; then \
		spec=$$(awk 'BEGIN{name=""; version=""} \
			/^name = / && name == "" { gsub(/"/, "", $$3); name = $$3 } \
			/^version = / && version == "" { gsub(/"/, "", $$3); version = $$3 } \
			END { if (name != "" && version != "") printf "%s@%s", name, version }' "$$crate_dir/Cargo.toml"); \
		if [ -n "$$spec" ]; then printf -- "-p %s --test %s " "$$spec" "$$base"; fi; \
	fi; \
done)
INTEGRATION_TEST_TARGETS += -p $(call PKG_SPEC_FROM_TOML,libmenotify/Cargo.toml) --test githubissues_demo_it
CORE_EXCLUDES := $(foreach pkg,$(ALL_MODULE_PACKAGE_SPECS),--exclude $(pkg))
TEST_BUILD_JOBS ?= $(shell sh -c 'n=$$(command -v nproc >/dev/null 2>&1 && nproc || sysctl -n hw.ncpu 2>/dev/null || echo 2); if [ "$$n" -gt 2 ]; then echo $$((($$n + 1) / 2)); else echo 1; fi')
TEST_RUN_THREADS ?= 3
ifeq ($(UNAME_S),Linux)
CURRENT_PLATFORM := linux
ifeq ($(UNAME_M),x86_64)
CURRENT_ARCH := x86_64
CURRENT_MUSL_TARGET := x86_64-unknown-linux-musl
CURRENT_MUSL_CC := x86_64-linux-musl-gcc
else ifeq ($(UNAME_M),aarch64)
CURRENT_ARCH := arm64
CURRENT_MUSL_TARGET := aarch64-unknown-linux-musl
CURRENT_MUSL_CC := aarch64-linux-musl-gcc
else ifeq ($(UNAME_M),arm64)
CURRENT_ARCH := arm64
CURRENT_MUSL_TARGET := aarch64-unknown-linux-musl
CURRENT_MUSL_CC := aarch64-linux-musl-gcc
else
CURRENT_ARCH := unknown
CURRENT_MUSL_TARGET :=
CURRENT_MUSL_CC :=
endif
else ifeq ($(UNAME_S),FreeBSD)
CURRENT_PLATFORM := freebsd
CURRENT_ARCH := $(UNAME_M)
CURRENT_MUSL_TARGET :=
CURRENT_MUSL_CC :=
else ifeq ($(UNAME_S),NetBSD)
CURRENT_PLATFORM := netbsd
CURRENT_ARCH := $(UNAME_M)
CURRENT_MUSL_TARGET :=
CURRENT_MUSL_CC :=
else ifeq ($(UNAME_S),OpenBSD)
CURRENT_PLATFORM := openbsd
CURRENT_ARCH := $(UNAME_M)
CURRENT_MUSL_TARGET :=
CURRENT_MUSL_CC :=
else
CURRENT_PLATFORM := unknown
CURRENT_ARCH := unknown
CURRENT_MUSL_TARGET :=
CURRENT_MUSL_CC :=
endif
CURRENT_MINION_SLOT := $(CURRENT_PLATFORM)/$(CURRENT_ARCH)
SYSINSPECT_SPEC := $(call PKG_SPEC_FROM_TOML,Cargo.toml)
SYSMINION_SPEC := $(call PKG_SPEC_FROM_TOML,sysminion/Cargo.toml)

define deps
	@need_apt=0; \
	for cmd in pkg-config clang protoc; do \
		command -v $$cmd >/dev/null 2>&1 || need_apt=1; \
	done; \
	if [ "$$need_apt" -eq 1 ]; then \
		if ! command -v apt-get >/dev/null 2>&1; then \
			echo "Missing required build tools (pkg-config/clang/protoc) and no apt-get is available to install them." >&2; \
			exit 1; \
		fi; \
		SUDO=$$(command -v sudo >/dev/null 2>&1 && echo sudo || true); \
		echo "Installing required packages: pkg-config, libssl-dev, libffi-dev, libsodium-dev, libpam0g-dev, llvm-dev, libclang-dev, clang, protobuf-compiler"; \
		$$SUDO apt-get update && $$SUDO apt-get install -y pkg-config libssl-dev libffi-dev libsodium-dev libpam0g-dev llvm-dev libclang-dev clang protobuf-compiler; \
	fi; \
	cargo nextest --version >/dev/null 2>&1 || cargo install cargo-nextest --locked; \
	command -v tokei >/dev/null 2>&1 || cargo install tokei --locked
endef

define tgt
	@t=$(1); \
	rustup target list --installed | grep -qx "$$t" || { \
		echo "Adding target $$t"; \
		rustup target add $$t; \
	}
endef

define check_present
	@if ! command -v $(1) >/dev/null 2>&1; then \
		echo "Error: '$(1)' is not found, aborting." >&2; \
		exit 1; \
	fi
endef

define prep_layout
	@dir=$$(if [ -n "$(2)" ]; then echo target/$(2)/$(1); else echo target/$(1); fi); \
	for layout in $(PACK_LAYOUT_DIRS); do \
		if [ -d $$dir/$$layout ]; then rm -rf $$dir/$$layout; fi; \
	done
endef

define move_bin
	@dir=$$(if [ -n "$(2)" ]; then echo target/$(2)/$(1); else echo target/$(1); fi); \
	echo "Moving binaries in $$dir"; \
	if [ -f $$dir/net ]; then mv $$dir/net $$dir/.net.bin; fi; \
	if [ -f $$dir/http ]; then mv $$dir/http $$dir/.http.bin; fi; \
	rm -rf $$dir/sys; \
	mkdir -p $$dir/sys; \
	rm -rf $$dir/net; \
	mkdir -p $$dir/net; \
	rm -rf $$dir/fs; \
	mkdir -p $$dir/fs; \
	rm -rf $$dir/runtime; \
	mkdir -p $$dir/runtime; \
	rm -rf $$dir/cfg; \
	mkdir -p $$dir/cfg; \
	if [ -f $$dir/proc ]; then mv $$dir/proc $$dir/sys/; fi; \
	if [ -f $$dir/.net.bin ]; then mv $$dir/.net.bin $$dir/sys/net; fi; \
	if [ -f $$dir/run ]; then mv $$dir/run $$dir/sys/; fi; \
	if [ -f $$dir/ssrun ]; then mv $$dir/ssrun $$dir/sys/; fi; \
	if [ -f $$dir/.http.bin ]; then mv $$dir/.http.bin $$dir/net/http; fi; \
	if [ -f $$dir/file ]; then mv $$dir/file $$dir/fs/; fi; \
	if [ -f $$dir/lua-runtime ]; then mv $$dir/lua-runtime $$dir/runtime/; fi; \
	if [ -f $$dir/py3-runtime ]; then mv $$dir/py3-runtime $$dir/runtime/; fi; \
	if [ -f $$dir/wasm-runtime ]; then mv $$dir/wasm-runtime $$dir/runtime/; fi; \
	if [ -f $$dir/resource ]; then mv $$dir/resource $$dir/cfg/; fi;
endef

define stage_modules_dist
	@dist=target/modules-dist; \
	rm -rf "$$dist"; \
	mkdir -p "$$dist"; \
	find modules -maxdepth 3 -name Cargo.toml -print | sort | while read f; do \
		pkg=$$(awk 'BEGIN{name=""} /^name = / && name == "" { gsub(/"/, "", $$3); name = $$3 } END { print name }' "$$f"); \
		srcdir=$$(dirname "$$f"); \
		bin=target/release/$$pkg; \
		spec=$$srcdir/src/mod_doc.yaml; \
		dstdir=$$dist/$$pkg; \
		if [ ! -f "$$bin" ]; then echo "Skipping missing built module binary: $$bin"; continue; fi; \
		if [ ! -f "$$spec" ]; then echo "Skipping module without spec source: $$spec"; continue; fi; \
		mkdir -p "$$dstdir"; \
		cp "$$bin" "$$dstdir/$$pkg"; \
		chmod +x "$$dstdir/$$pkg"; \
		cp "$$spec" "$$dstdir/$$pkg.spec"; \
	done
endef

define stage_modules_dist_from
	@dist=target/modules-dist; \
	build_dir=target/$(2)/$(1); \
	rm -rf "$$dist"; \
	mkdir -p "$$dist"; \
	find modules -maxdepth 3 -name Cargo.toml -print | sort | while read f; do \
		pkg=$$(awk 'BEGIN{name=""} /^name = / && name == "" { gsub(/"/, "", $$3); name = $$3 } END { print name }' "$$f"); \
		srcdir=$$(dirname "$$f"); \
		bin=$$build_dir/$$pkg; \
		spec=$$srcdir/src/mod_doc.yaml; \
		dstdir=$$dist/$$pkg; \
		if [ ! -f "$$bin" ]; then echo "Skipping missing built module binary: $$bin"; continue; fi; \
		if [ ! -f "$$spec" ]; then echo "Skipping module without spec source: $$spec"; continue; fi; \
		mkdir -p "$$dstdir"; \
		cp "$$bin" "$$dstdir/$$pkg"; \
		chmod +x "$$dstdir/$$pkg"; \
		cp "$$spec" "$$dstdir/$$pkg.spec"; \
	done
endef

define stage_native_modules_dist
	@dist=target/modules-dist; \
	build_dir=target/$(1); \
	mkdir -p "$$dist"; \
	for spec in $(NATIVE_REFRESH_PACKAGE_SPECS); do \
		pkg=$${spec%@*}; \
		srcdir=$$(find modules -maxdepth 3 -name Cargo.toml -print | sort | while read f; do \
			name=$$(awk 'BEGIN{name=""} /^name = / && name == "" { gsub(/"/, "", $$3); name = $$3 } END { print name }' "$$f"); \
			if [ "$$name" = "$$pkg" ]; then dirname "$$f"; break; fi; \
		done); \
		bin=$$build_dir/$$pkg; \
		spec=$$srcdir/src/mod_doc.yaml; \
		dstdir=$$dist/$$pkg; \
		if [ ! -f "$$bin" ]; then echo "Skipping missing native module binary: $$bin"; continue; fi; \
		if [ ! -f "$$spec" ]; then echo "Skipping module without spec source: $$spec"; continue; fi; \
		mkdir -p "$$dstdir"; \
		cp "$$bin" "$$dstdir/$$pkg"; \
		chmod +x "$$dstdir/$$pkg"; \
		cp "$$spec" "$$dstdir/$$pkg.spec"; \
	done
endef

define refresh_modules_repo
	@sysbin=target/debug/sysinspect; \
	if [ ! -x "$$sysbin" ]; then \
		echo "Building debug sysinspect helper"; \
		cargo build -v -p $(call PKG_SPEC_FROM_TOML,Cargo.toml); \
	fi; \
	"$$sysbin" module -R -n '*'; \
	find target/modules-dist -mindepth 2 -maxdepth 2 -type f ! -name '*.spec' | sort | while read mod; do \
		echo "Installing $$mod"; \
		"$$sysbin" module -A --path "$$mod"; \
	done; \
	for libpath in $(STATIC_LIBRARY_PAYLOAD_PATHS); do \
		if [ -d "$$libpath" ]; then \
			echo "Installing library payload $$libpath"; \
			"$$sysbin" module -A --path "$$libpath" -l; \
		fi; \
	done; \
	if [ -z "$(WASM_DEMO_COMPILER)" ]; then \
		echo "Missing Go or TinyGo for Wasm example payload refresh. Override WASM_DEMO_COMPILER=go or WASM_DEMO_COMPILER=tinygo." >&2; \
		exit 1; \
	fi; \
	echo "Refreshing Wasm example payloads with WASM_DEMO_COMPILER=$(WASM_DEMO_COMPILER)"; \
	$(MAKE) -C modules/runtime/wasm-runtime/examples/hello WASM_COMPILER=$(WASM_DEMO_COMPILER) release; \
	if [ ! -d modules/runtime/wasm-runtime/examples/hello/build/lib ]; then \
		echo "Missing Wasm example payload: modules/runtime/wasm-runtime/examples/hello/build/lib" >&2; \
		exit 1; \
	fi; \
	"$$sysbin" module -A --path modules/runtime/wasm-runtime/examples/hello/build/lib -l; \
	$(MAKE) -C modules/runtime/wasm-runtime/examples/caller WASM_COMPILER=$(WASM_DEMO_COMPILER) release; \
	if [ ! -d modules/runtime/wasm-runtime/examples/caller/build/lib ]; then \
		echo "Missing Wasm example payload: modules/runtime/wasm-runtime/examples/caller/build/lib" >&2; \
		exit 1; \
	fi; \
	"$$sysbin" module -A --path modules/runtime/wasm-runtime/examples/caller/build/lib -l; \
	$(MAKE) -C modules/runtime/wasm-runtime/examples/rs-reader; \
	if [ ! -d modules/runtime/wasm-runtime/examples/rs-reader/target/release/lib ]; then \
		echo "Missing Wasm example payload: modules/runtime/wasm-runtime/examples/rs-reader/target/release/lib" >&2; \
		exit 1; \
	fi; \
	"$$sysbin" module -A --path modules/runtime/wasm-runtime/examples/rs-reader/target/release/lib -l
endef

define refresh_current_minion_repo
	@sysbin=target/debug/sysinspect; \
	if [ ! -x "$$sysbin" ]; then \
		echo "Building debug sysinspect helper"; \
		cargo build -v -p $(SYSINSPECT_SPEC); \
	fi; \
	if [ -z "$(CURRENT_MUSL_TARGET)" ] || [ -z "$(CURRENT_MUSL_CC)" ]; then \
		echo "Current host $(UNAME_S)/$(UNAME_M) does not have a configured musl refresh target." >&2; \
		exit 1; \
	fi; \
	minion=target/$(CURRENT_MUSL_TARGET)/debug/sysminion; \
	if [ ! -x "$$minion" ]; then \
		echo "Missing built minion binary: $$minion" >&2; \
		exit 1; \
	fi; \
	"$$sysbin" module -R -t --name $(CURRENT_MINION_SLOT) || true; \
	"$$sysbin" module -A -t -p "$$minion"
endef
